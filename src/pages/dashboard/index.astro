---
// Importaciones se mantienen intactas
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StatCard from '../../components/dashboard/StatCard.astro';
import Operaciones from '../../components/dashboard/operaciones.astro';
import Comisiones from '../../components/dashboard/comisiones.astro';
import BalanceLedger from '../../components/dashboard/BalanceLedger.astro';
import Profit from '../../components/dashboard/profit.astro';
import ComisionOperador from '../../components/dashboard/ComisionOperador.astro'; 
import ProyeccionGanancias from '../../components/dashboard/ProyeccionGanancias.astro';
import 'flatpickr/dist/flatpickr.min.css';
import 'flatpickr/dist/themes/dark.css';
---

<DashboardLayout>
  <!-- MODAL DE COBERTURA PENDIENTE -->
  <div id="coverage-alert-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm transition-opacity duration-300 opacity-0 px-4">
    <div class="relative w-full max-w-md scale-95 transform rounded-[2rem] border border-white bg-white p-8 shadow-[0_20px_50px_rgba(225,29,72,0.30)] transition-all duration-300">
      <div class="absolute -top-6 left-1/2 flex h-14 w-14 -translate-x-1/2 items-center justify-center rounded-full border-4 border-white bg-rose-500 shadow-lg shadow-rose-500/30">
        <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <div class="mt-4 text-center">
        <h3 class="mb-3 text-[14px] font-black uppercase tracking-[0.2em] text-gray-900">Alerta de Seguridad</h3>
        <p class="mb-8 text-base font-black leading-relaxed text-rose-600">NO HAS COMPLETADO TUS COBERTURAS DEBES COMPLETARLO AHORA MISMO</p>
        <div class="flex items-center justify-center space-x-2 text-rose-500 text-[13px] font-black uppercase tracking-[0.1em]">
          <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span>Esperando sincronización...</span>
        </div>
      </div>
    </div>
  </div>
  <script is:inline>
    // Se utilizará para mostrar el modal localmente
    window.showCoverageAlertModal = function() {
      const modal = document.getElementById('coverage-alert-modal');
      const wrap = modal?.querySelector('div');
      if (modal && wrap && modal.classList.contains('hidden')) {
        modal.classList.remove('hidden');
        // Pequeño delay para la transición
        setTimeout(() => {
          modal.classList.remove('opacity-0');
          modal.classList.add('opacity-100');
          wrap.classList.remove('scale-95');
          wrap.classList.add('scale-100');
        }, 10);
      }
    };

    window.hideCoverageAlertModal = function() {
      const modal = document.getElementById('coverage-alert-modal');
      const wrap = modal?.querySelector('div');
      if (modal && wrap && !modal.classList.contains('hidden')) {
        // Animación de salida
        modal.classList.remove('opacity-100');
        modal.classList.add('opacity-0');
        wrap.classList.remove('scale-100');
        wrap.classList.add('scale-95');
        setTimeout(() => {
          modal.classList.add('hidden');
        }, 300);
      }
    };
  </script>

  <!-- Impersonacion Admin: aceptar ?impersonate=<token>&alias=<alias> -->
  <script is:inline>
    (function handleImpersonation() {
      const params = new URLSearchParams(window.location.search);
      const impToken = params.get('impersonate');
      const impAlias = params.get('alias');
      if (impToken) {
        sessionStorage.setItem('auth_token', impToken);
        sessionStorage.setItem('user_role', 'operator');
        sessionStorage.setItem('operator_alias', impAlias || 'Operador');
        sessionStorage.setItem('user_info', JSON.stringify({ alias: impAlias || 'Operador' }));
        sessionStorage.setItem('admin_impersonation', 'true');
        // Clean URL without reloading
        const cleanUrl = window.location.pathname;
        window.history.replaceState({}, '', cleanUrl);
      }
    })();
  </script>
  <!-- Proteccion de Ruta: Redirigir Inversores al Hub correcto -->
  <script is:inline>
    const userRole = sessionStorage.getItem('user_role');
    if (userRole === 'investor') {
      window.location.href = '/investor';
    }
  </script>
  <!-- Banner de impersonación admin -->
  <div id="admin-impersonation-banner" class="hidden mb-4 mx-1 sm:mx-2 flex items-center gap-3 rounded-xl border border-[#F3BA2F]/30 bg-[#F3BA2F]/10 px-4 py-2.5 text-sm">
    <span class="text-[#F3BA2F] font-black text-xs uppercase tracking-[0.15em]">Admin</span>
    <span class="text-white/80">Viendo dashboard de <strong id="impersonation-alias" class="text-[#F3BA2F]"></strong> en modo admin</span>
    <button onclick="sessionStorage.clear(); window.close();" class="ml-auto rounded-lg border border-white/10 bg-white/5 px-3 py-1 text-xs font-bold text-white/70 hover:bg-white/10 hover:text-white transition-colors">Cerrar</button>
  </div>
  <script is:inline>
    if (sessionStorage.getItem('admin_impersonation') === 'true') {
      const banner = document.getElementById('admin-impersonation-banner');
      if (banner) {
        banner.classList.remove('hidden');
        const aliasEl = document.getElementById('impersonation-alias');
        if (aliasEl) aliasEl.textContent = sessionStorage.getItem('operator_alias') || 'Operador';
      }
    }
  </script>

  <div class="mb-8 flex flex-col gap-2 px-1 sm:mb-10 sm:px-2">
    <div class="max-w-3xl">
      <h1 class="break-words text-[1.7rem] font-black uppercase tracking-tight text-white sm:text-[2.1rem] md:text-[2.55rem]">
        Bienvenido, <span id="operator-alias" class="text-[#F3BA2F]">Cargando...</span>
      </h1>
      <div class="mt-3 flex flex-col gap-1.5">
        <p id="last-update" class="text-[11px] text-gray-500 uppercase font-black tracking-[0.18em] italic sm:text-[12px]">
          Sincronizando con Sentinel...
        </p>
        <p id="kpi-filter-label" class="text-[11px] text-emerald-500/80 uppercase font-black tracking-[0.18em] sm:text-[12px]">
          Rango activo: Hoy
        </p>
      </div>
    </div>
  </div>

  <section class="dashboard-collapsible mb-8 rounded-[1.75rem] border border-gray-800 bg-gradient-to-br from-[#0f1216] to-[#0b0d11] shadow-xl shadow-black/40 sm:mb-10"
    data-collapsible="kpi-filter">
    <button class="dashboard-collapsible-trigger" type="button" data-collapsible-trigger aria-expanded="true">
      <span class="dashboard-collapsible-title-wrap">
        <span class="w-1.5 h-5 bg-[#F3BA2F]"></span>
        <span class="text-[11px] font-black uppercase tracking-[0.2em] text-gray-300 sm:text-[12px] sm:tracking-[0.28em]">Filtro temporal KPI</span>
      </span>
      <span class="dashboard-collapsible-icon" aria-hidden="true">▾</span>
    </button>
    <div class="dashboard-collapsible-body p-4 pt-0 sm:p-6 sm:pt-0 lg:p-7 lg:pt-0" data-collapsible-body>
      <div class="scrollbar-hide mb-8 flex gap-3 overflow-x-auto pb-4" id="kpi-preset-group">
        {[
          { id: 'all', label: 'Todo' },
          { id: 'last_30', label: 'Ultimos 30 dias' },
          { id: 'this_month', label: 'Mes actual' },
          { id: 'last_7', label: 'Ultimos 7 dias' },
          { id: 'this_week', label: 'Esta semana' },
          { id: 'yesterday', label: 'Ayer' },
          { id: 'today', label: 'Hoy' }
        ].map((preset) => (
          <button 
            class={`kpi-preset-btn whitespace-nowrap rounded-xl border bg-white/5 px-4 py-3 text-[11px] font-black uppercase shadow-md transition-all hover:border-[#F3BA2F]/60 hover:text-[#F3BA2F] sm:px-6 sm:text-[12px] ${preset.id === 'today' ? 'kpi-preset-btn-active' : 'border-gray-800'}`}
            data-preset={preset.id}
          >
            {preset.label}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
      <div class="space-y-2">
          <label class="sentinel-label px-1">Desde</label>
          <div class="relative group">
              <input id="kpi-date-from" type="text" placeholder="Seleccionar fecha..." class="w-full cursor-pointer rounded-xl border border-white-700 bg-black p-4 pl-11 text-[15px] text-white shadow-inner outline-none transition-all focus:border-[#F3BA2F]/70 focus:bg-white/5 sm:text-base" readonly />
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 group-hover:text-[#F3BA2F] transition-colors pointer-events-none">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              </div>
          </div>
        </div>
        <div class="space-y-2">
          <label class="sentinel-label px-1">Hasta</label>
          <div class="relative group">
              <input id="kpi-date-to" type="text" placeholder="Seleccionar fecha..." class="w-full cursor-pointer rounded-xl border border-white-700 bg-black p-4 pl-11 text-[15px] text-white shadow-inner outline-none transition-all focus:border-[#F3BA2F]/70 focus:bg-white/5 sm:text-base" readonly />
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 group-hover:text-[#F3BA2F] transition-colors pointer-events-none">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              </div>
          </div>
        </div>
        <div class="flex items-end">
          <button id="kpi-apply-range" class="w-full rounded-xl bg-[#F3BA2F] px-4 text-[12px] font-black uppercase tracking-[0.2em] text-black shadow-lg shadow-[#F3BA2F]/20 transition-all hover:bg-[#d9a927] active:scale-[0.98] sm:text-[13px]">
            Actualizar Reporte
          </button>
        </div>
      </div>
    </div>
  </section>

  <section class="dashboard-collapsible mb-2 lg:mb-3" data-collapsible="critical-performance">
    <button class="dashboard-collapsible-trigger dashboard-collapsible-trigger-section px-1 sm:px-2" type="button" data-collapsible-trigger aria-expanded="true">
      <span class="dashboard-collapsible-title-wrap">
        <span class="w-1.5 h-4 bg-[#F3BA2F]"></span>
        <span class="break-words text-[11px] font-black uppercase italic tracking-[0.18em] text-[#F3BA2F] sm:text-[13px] sm:tracking-[0.26em]">1. RENDIMIENTO DE OPERACIONES CRITICAS</span>
      </span>
      <span class="dashboard-collapsible-icon" aria-hidden="true">▾</span>
    </button>
    <div class="dashboard-collapsible-body" data-collapsible-body>
      <div class="grid grid-cols-1 gap-6 xl:gap-7">
        <div id="dashboard-profit-panel" class="w-full">
          <Profit />
        </div>
      </div>
    </div>
  </section>

  <section class="dashboard-collapsible mb-12" data-collapsible="ops-insights">
    <button class="dashboard-collapsible-trigger dashboard-collapsible-trigger-section px-1 sm:px-2" type="button" data-collapsible-trigger aria-expanded="true">
      <span class="dashboard-collapsible-title-wrap">
        <span class="w-1.5 h-4 bg-[#F3BA2F]"></span>
        <span class="break-words text-[11px] font-black uppercase italic tracking-[0.18em] text-[#F3BA2F] sm:text-[13px] sm:tracking-[0.26em]">2. CONTROL DE OPERACIONES Y VOLUMEN + 4. PROYECCIONES E INSIGHTS</span>
      </span>
      <span class="dashboard-collapsible-icon" aria-hidden="true">▾</span>
    </button>
    <div class="dashboard-collapsible-body" data-collapsible-body>
      <div class="grid grid-cols-1 gap-8 xl:grid-cols-2 xl:gap-8">
        <section class="self-start">
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <Operaciones />
            <Comisiones />
          </div>
        </section>

        <section class="self-start">
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <ProyeccionGanancias />
            <ComisionOperador />
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="mb-12 lg:mb-14">
    
    <h2 class="mb-6 flex items-center gap-3 break-words px-1 text-[11px] font-black uppercase italic tracking-[0.18em] text-[#F3BA2F] sm:px-2 sm:text-[13px] sm:tracking-[0.26em]">
      <span class="w-1.5 h-4 bg-[#F3BA2F]"></span> 3. LOGISTICA DE CARTERAS (BALANCES INTERNOS)
    </h2>
    <BalanceLedger />
  </section>
  <script>
    import { initDashboard } from '../../scripts/dashboard.js';
    initDashboard();
  </script>
  <script is:inline>
    (() => {
      const STORAGE_KEY = 'dashboard_collapsible_sections_v1';
      const sections = Array.from(document.querySelectorAll('[data-collapsible]'));
      const savedState = (() => {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
        } catch (_error) {
          return {};
        }
      })();

      const syncSection = (section, open) => {
        const trigger = section.querySelector('[data-collapsible-trigger]');
        const body = section.querySelector('[data-collapsible-body]');
        if (!trigger || !body) return;
        section.dataset.collapsed = open ? 'false' : 'true';
        trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
        body.hidden = !open;
      };

      sections.forEach((section) => {
        const id = section.getAttribute('data-collapsible');
        const trigger = section.querySelector('[data-collapsible-trigger]');
        if (!id || !trigger) return;

        const isOpen = savedState[id] !== false;
        syncSection(section, isOpen);

        trigger.addEventListener('click', () => {
          const nextOpen = section.dataset.collapsed === 'true';
          syncSection(section, nextOpen);
          savedState[id] = nextOpen;
          try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(savedState));
          } catch (_error) {}
        });
      });
    })();
  </script>
  
</DashboardLayout>



<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .kpi-preset-btn-active {
    border-color: #F3BA2F;
    background: rgba(243, 186, 47, 0.10);
    color: #F3BA2F;
  }

  .dashboard-collapsible-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1rem 1.15rem;
    background: transparent;
    border: 0;
    cursor: pointer;
    text-align: left;
  }

  .dashboard-collapsible-trigger-section {
    padding: 0 0 1.15rem;
  }

  .dashboard-collapsible-title-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .dashboard-collapsible-icon {
    flex-shrink: 0;
    color: rgba(243, 186, 47, 0.9);
    font-size: 1rem;
    line-height: 1;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .dashboard-collapsible[data-collapsed="true"] .dashboard-collapsible-icon {
    transform: rotate(-90deg);
    opacity: 0.85;
  }

  .dashboard-collapsible[data-collapsed="true"] .dashboard-collapsible-trigger {
    padding-bottom: 1rem;
  }
  
  /* Ajuste para el alto del boton de aplicar */
  #kpi-apply-range {
    height: 52px;
  }

  @media (min-width: 640px) {
    #kpi-apply-range {
      height: 58px;
    }
  }
</style>
