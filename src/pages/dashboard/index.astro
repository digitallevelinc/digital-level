---
// Importaciones se mantienen intactas
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import StatCard from '../../components/dashboard/StatCard.astro';
import Operaciones from '../../components/dashboard/operaciones.astro';
import Comisiones from '../../components/dashboard/comisiones.astro';
import BalanceLedger from '../../components/dashboard/BalanceLedger.astro';
import Profit from '../../components/dashboard/profit.astro';
import ComisionOperador from '../../components/dashboard/ComisionOperador.astro'; 
import ProyeccionGanancias from '../../components/dashboard/ProyeccionGanancias.astro';
import AnunciosActivos from '../../components/dashboard/anunciosActivos.astro';
import 'flatpickr/dist/flatpickr.min.css';
import 'flatpickr/dist/themes/dark.css';
---

<DashboardLayout>
  <!-- Impersonacion Admin: aceptar ?impersonate=<token>&alias=<alias> -->
  <script is:inline>
    (function handleImpersonation() {
      const params = new URLSearchParams(window.location.search);
      const impToken = params.get('impersonate');
      const impAlias = params.get('alias');
      if (impToken) {
        sessionStorage.setItem('auth_token', impToken);
        sessionStorage.setItem('user_role', 'operator');
        sessionStorage.setItem('operator_alias', impAlias || 'Operador');
        sessionStorage.setItem('user_info', JSON.stringify({ alias: impAlias || 'Operador' }));
        sessionStorage.setItem('admin_impersonation', 'true');
        // Clean URL without reloading
        const cleanUrl = window.location.pathname;
        window.history.replaceState({}, '', cleanUrl);
      }
    })();
  </script>
  <!-- Proteccion de Ruta: Redirigir Inversores al Hub correcto -->
  <script is:inline>
    const userRole = sessionStorage.getItem('user_role');
    if (userRole === 'investor') {
      window.location.href = '/investor';
    }
  </script>
  <!-- Banner de impersonación admin -->
  <div id="admin-impersonation-banner" class="hidden mb-4 mx-1 sm:mx-2 flex items-center gap-3 rounded-xl border border-[#F3BA2F]/30 bg-[#F3BA2F]/10 px-4 py-2.5 text-sm">
    <span class="text-[#F3BA2F] font-black text-xs uppercase tracking-[0.15em]">Admin</span>
    <span class="text-white/80">Viendo dashboard de <strong id="impersonation-alias" class="text-[#F3BA2F]"></strong> en modo lectura</span>
    <button onclick="sessionStorage.clear(); window.close();" class="ml-auto rounded-lg border border-white/10 bg-white/5 px-3 py-1 text-xs font-bold text-white/70 hover:bg-white/10 hover:text-white transition-colors">Cerrar</button>
  </div>
  <script is:inline>
    if (sessionStorage.getItem('admin_impersonation') === 'true') {
      const banner = document.getElementById('admin-impersonation-banner');
      if (banner) {
        banner.classList.remove('hidden');
        const aliasEl = document.getElementById('impersonation-alias');
        if (aliasEl) aliasEl.textContent = sessionStorage.getItem('operator_alias') || 'Operador';
      }
    }
  </script>

  <div class="mb-8 flex flex-col justify-between gap-5 px-1 sm:mb-10 sm:px-2 xl:flex-row xl:items-center">
    <div class="max-w-3xl">
      <h1 class="break-words text-[1.7rem] font-black uppercase tracking-tight text-white sm:text-[2.1rem] md:text-[2.55rem]">
        Bienvenido, <span id="operator-alias" class="text-[#F3BA2F]">Cargando...</span>
      </h1>
      <div class="mt-3 flex flex-col gap-1.5">
        <p id="last-update" class="text-[11px] text-gray-500 uppercase font-black tracking-[0.18em] italic sm:text-[12px]">
          Sincronizando con Sentinel...
        </p>
        <p id="kpi-filter-label" class="text-[11px] text-emerald-500/80 uppercase font-black tracking-[0.18em] sm:text-[12px]">
          Rango activo: Hoy
        </p>
      </div>
    </div>
    
        

    <div class="flex w-full flex-wrap items-center gap-2 rounded-2xl border border-white/5 bg-[#1e2329]/20 p-2.5 backdrop-blur-sm sm:gap-3 xl:w-auto xl:flex-nowrap">
    

  
    <div id="dashboard-notifications" class="relative">
      <button
        id="dashboard-notifications-btn"
        type="button"
        aria-expanded="false"
        aria-controls="dashboard-notifications-panel"
        class="group relative flex h-11 w-11 items-center justify-center rounded-xl border border-[#F3BA2F]/20 bg-[#F3BA2F]/10 text-[#F3BA2F] shadow-lg transition-all duration-300 hover:border-[#F3BA2F]/50 hover:bg-[#F3BA2F]/20 sm:h-12 sm:w-12"
        title="Notificaciones de promesas"
      >
        <i class="fas fa-bell text-base transition-transform group-hover:scale-110"></i>
        <span id="dashboard-notifications-badge" class="hidden absolute -right-1 -top-1 min-w-[1.25rem] rounded-full bg-rose-500 px-1.5 py-0.5 text-[10px] font-black text-white shadow-lg shadow-rose-500/30">0</span>
      </button>

      <div
        id="dashboard-notifications-panel"
        class="hidden absolute right-0 top-[calc(100%+0.75rem)] z-[1200] w-[min(420px,calc(100vw-1.5rem))] overflow-hidden rounded-[1.35rem] border border-white/10 bg-[#11161c]/95 shadow-[0_24px_60px_rgba(0,0,0,0.55)] backdrop-blur-xl"
      >
        <div class="flex items-center justify-between gap-3 border-b border-white/10 px-4 py-4">
          <div>
            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-[#F3BA2F]">Inbox</p>
            <p class="mt-1 text-sm font-black uppercase tracking-[0.14em] text-white">Alertas</p>
          </div>
          <div class="flex gap-2">
            <button
              id="dashboard-notifications-send-note"
              type="button"
              class="rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-2 text-[10px] font-black uppercase tracking-[0.14em] text-blue-400 transition-colors hover:border-blue-400/40 hover:text-blue-300"
            >
              Enviar nota
            </button>
            <button
              id="dashboard-notifications-mark-read"
              type="button"
              class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-[10px] font-black uppercase tracking-[0.14em] text-white/70 transition-colors hover:border-[#F3BA2F]/40 hover:text-[#F3BA2F]"
            >
              Marcar todo
            </button>
          </div>
        </div>
        <div id="dashboard-notifications-list" class="max-h-[360px] space-y-3 overflow-y-auto p-3">
          <div class="px-4 py-5 text-center text-sm font-bold text-white/50">Sin notificaciones por ahora.</div>
        </div>
      </div>
    </div>

    <a
        id="link-p2p-sheet"
        href="#"
        class="group flex h-11 w-11 items-center justify-center rounded-xl border border-emerald-500/10 bg-emerald-500/5 text-emerald-500 shadow-lg transition-all duration-300 hover:border-emerald-500/40 hover:bg-emerald-500/20 sm:h-12 sm:w-12"
        title="Exportar rango a Excel"
        onclick="return false;"
    >
        <svg class="w-6 h-6 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2zM19 20H5V4h8v4h6v12zM7 18h10v-2H7v2zm0-4h10v-2H7v2zm0-4h10V8H7v2z" />
        </svg>
    </a>

    <div class="w-px h-6 bg-white/10 mx-1 hidden md:block"></div>

    <a
        href="https://www.digitalevel.com/admin/"
        class="h-11 flex-1 rounded-xl border border-white/10 bg-white/[0.04] px-4 text-center text-[11px] font-black uppercase tracking-[0.16em] text-white/80 shadow-lg transition-all duration-300 hover:border-[#F3BA2F]/40 hover:bg-[#F3BA2F]/10 hover:text-[#F3BA2F] active:scale-95 sm:h-12 sm:px-6 sm:text-[12px] sm:tracking-[0.2em] xl:flex-none inline-flex items-center justify-center"
    >
        Inicio
    </a>
    
    <button 
        id="logout-btn" 
        class="h-11 flex-1 rounded-xl border border-red-500/10 bg-red-500/5 px-4 text-[11px] font-black uppercase tracking-[0.16em] text-red-500 shadow-lg transition-all duration-300 hover:border-red-500/40 hover:bg-red-500/20 active:scale-95 sm:h-12 sm:px-6 sm:text-[12px] sm:tracking-[0.2em] xl:flex-none"
    >
        Cerrar Sesion
    </button>
</div>

  </div>

  <section class="mb-10 rounded-[1.75rem] border border-gray-800 bg-gradient-to-br from-[#0f1216] to-[#0b0d11] p-4 shadow-xl shadow-black/40 sm:mb-12 sm:p-6 lg:p-7">
    <div class="mb-5 flex items-center gap-3">
      <span class="w-1.5 h-5 bg-[#F3BA2F]"></span>
      <p class="text-[11px] font-black uppercase tracking-[0.2em] text-gray-300 sm:text-[12px] sm:tracking-[0.28em]">Filtro temporal KPI</p>
    </div>

    <div class="scrollbar-hide mb-8 flex gap-3 overflow-x-auto pb-4" id="kpi-preset-group">
      {[
        { id: 'all', label: 'Todo' },
        { id: 'last_30', label: 'Ultimos 30 dias' },
        { id: 'this_month', label: 'Mes actual' },
        { id: 'last_7', label: 'Ultimos 7 dias' },
        { id: 'this_week', label: 'Esta semana' },
        { id: 'yesterday', label: 'Ayer' },
        { id: 'today', label: 'Hoy' }
      ].map((preset) => (
        <button 
          class={`kpi-preset-btn whitespace-nowrap rounded-xl border bg-white/5 px-4 py-3 text-[11px] font-black uppercase shadow-md transition-all hover:border-[#F3BA2F]/60 hover:text-[#F3BA2F] sm:px-6 sm:text-[12px] ${preset.id === 'today' ? 'kpi-preset-btn-active' : 'border-gray-800'}`}
          data-preset={preset.id}
        >
          {preset.label}
        </button>
      ))}
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-6">
    <div class="space-y-2">
        <label class="sentinel-label px-1">Desde</label>
        <div class="relative group">
            <input id="kpi-date-from" type="text" placeholder="Seleccionar fecha..." class="w-full cursor-pointer rounded-xl border border-white-700 bg-black p-4 pl-11 text-[15px] text-white shadow-inner outline-none transition-all focus:border-[#F3BA2F]/70 focus:bg-white/5 sm:text-base" readonly />
            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 group-hover:text-[#F3BA2F] transition-colors pointer-events-none">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
        </div>
      </div>
      <div class="space-y-2">
        <label class="sentinel-label px-1">Hasta</label>
        <div class="relative group">
            <input id="kpi-date-to" type="text" placeholder="Seleccionar fecha..." class="w-full cursor-pointer rounded-xl border border-white-700 bg-black p-4 pl-11 text-[15px] text-white shadow-inner outline-none transition-all focus:border-[#F3BA2F]/70 focus:bg-white/5 sm:text-base" readonly />
            <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 group-hover:text-[#F3BA2F] transition-colors pointer-events-none">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
        </div>
      </div>
      <div class="flex items-end">
        <button id="kpi-apply-range" class="w-full rounded-xl bg-[#F3BA2F] px-4 text-[12px] font-black uppercase tracking-[0.2em] text-black shadow-lg shadow-[#F3BA2F]/20 transition-all hover:bg-[#d9a927] active:scale-[0.98] sm:text-[13px]">
          Actualizar Reporte
        </button>
      </div>
    </div>
  </section>

  <section class="mb-12 lg:mb-14">
    <h2 class="mb-6 flex items-center gap-3 break-words px-1 text-[11px] font-black uppercase italic tracking-[0.18em] text-[#F3BA2F] sm:px-2 sm:text-[13px] sm:tracking-[0.26em]">
      <span class="w-1.5 h-4 bg-[#F3BA2F]"></span> 1. RENDIMIENTO DE OPERACIONES CRITICAS
    </h2>
    <div class="grid grid-cols-1 gap-6 xl:gap-7">
      <div id="dashboard-profit-panel" class="w-full">
        <Profit />
      </div>
    </div>
  </section>

  <div class="mb-12 grid grid-cols-1 gap-8 xl:grid-cols-2 xl:gap-8">
    <section>
      <h2 class="mb-6 flex items-center gap-3 break-words px-1 text-[11px] font-black uppercase italic tracking-[0.18em] text-[#F3BA2F] sm:px-2 sm:text-[13px] sm:tracking-[0.26em]">
      <span class="w-1.5 h-4 bg-[#F3BA2F]"></span> 2. CONTROL DE OPERACIONES Y VOLUMEN
    </h2>
      
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <Operaciones />
        <Comisiones />
      </div>
    </section>

    <section>
      
      <h2 class="mb-6 flex items-center gap-3 break-words px-1 text-[11px] font-black uppercase italic tracking-[0.18em] text-[#F3BA2F] sm:px-2 sm:text-[13px] sm:tracking-[0.26em]">
      <span class="w-1.5 h-4 bg-[#F3BA2F]"></span> 4. PROYECCIONES E INSIGHTS
    </h2>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <ProyeccionGanancias />
        <ComisionOperador />
      </div>
    </section>
  </div>

  <section class="mb-12 lg:mb-14">
    <h2 class="mb-6 flex items-center gap-3 break-words px-1 text-[12px] font-black uppercase italic tracking-[0.16em] text-[#F3BA2F] sm:px-2 sm:text-[14px] sm:tracking-[0.22em]">
      <span class="w-1.5 h-4 bg-[#F3BA2F]"></span> MONITOR DE ORDENES P2P ACTIVAS
    </h2>
    <AnunciosActivos />
  </section>

  <section class="mb-12 lg:mb-14">
    
    <h2 class="mb-6 flex items-center gap-3 break-words px-1 text-[11px] font-black uppercase italic tracking-[0.18em] text-[#F3BA2F] sm:px-2 sm:text-[13px] sm:tracking-[0.26em]">
      <span class="w-1.5 h-4 bg-[#F3BA2F]"></span> 3. LOGISTICA DE CARTERAS (BALANCES INTERNOS)
    </h2>
    <BalanceLedger />
  </section>
  <script>
    import { initDashboard } from '../../scripts/dashboard.js';
    initDashboard();
  </script>
  
</DashboardLayout>



<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .kpi-preset-btn-active {
    border-color: #F3BA2F;
    background: rgba(243, 186, 47, 0.10);
    color: #F3BA2F;
  }
  
  /* Ajuste para el alto del boton de aplicar */
  #kpi-apply-range {
    height: 52px;
  }

  @media (min-width: 640px) {
    #kpi-apply-range {
      height: 58px;
    }
  }
</style>
