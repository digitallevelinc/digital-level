---
// Sentinel - Sidebar Auditor Pro (Estructura Blindada)
---
<div class="sidebar-auditor-shell fixed top-16 sm:top-20 lg:top-24 right-0 z-[1100] flex items-start pointer-events-none">
    
    <button 
        id="sidebar-trigger"
        type="button"
        aria-expanded="false"
        aria-controls="sidebar-panel"
        class="pointer-events-auto relative overflow-hidden mt-4 sm:mt-6 lg:mt-8 bg-[#161a1e] border-2 border-[#F3BA2F]/40 border-r-0 p-3 sm:p-3.5 rounded-l-2xl shadow-[-10px_0_30px_rgba(243,186,47,0.2)] transition-all hover:scale-105 group border-l-[5px] border-l-[#F3BA2F]"
    >
        <i class="fas fa-microchip text-[#F3BA2F] text-sm group-hover:rotate-12 transition-transform" id="trigger-icon"></i>
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-[#F3BA2F]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
    </button>

    <aside 
        id="sidebar-panel" 
        aria-hidden="true"
        class="sidebar-panel-shell w-0 overflow-hidden bg-[#12171d] transition-all duration-300 ease-in-out rounded-l-[1.2rem] sm:rounded-l-[2rem]"
    >
        <div class="w-full px-4 sm:pl-6 sm:pr-8 py-5 sm:py-6 h-full overflow-y-auto custom-scroll flex flex-col">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <p class="text-[13px] font-black text-[#F3BA2F] uppercase tracking-[0.2em]">Sentinel Auditor</p>
                    <p id="side-range-label" class="text-[11px] text-gray-500 uppercase font-bold tracking-widest mt-0.5">Rango Activo + Wallet Live</p>
                </div>

                <button
                    id="sidebar-close"
                    type="button"
                    class="sidebar-close-btn"
                    aria-label="Cerrar auditor"
                    title="Cerrar auditor"
                >
                    <i class="fas fa-times"></i>
                </button>
            </div>

            
            <div class="space-y-4 mb-6">
                <div class="bg-[#1b2128] p-5 rounded-2xl border border-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.02)]">
                    <div class="min-w-0">
                        <p id="side-ceiling-level-label" class="text-[11px] font-black text-rose-400 uppercase tracking-[0.18em]">Venta actual</p>
                        <p id="side-ceiling-level-value" class="text-[1.45rem] leading-tight mt-2 font-black text-white tracking-tight">0,00</p>
                        <p id="side-ceiling-level-meta" class="text-[10px] text-cyan-300 uppercase font-black tracking-[0.15em] mt-2">Nivel sin data</p>
                    </div>
                </div>
                <div class="bg-[#171d24] p-4 rounded-xl border border-white/10 shadow-[inset_0_1px_0_rgba(255,255,255,0.02)]">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <p class="text-[9px] font-black text-slate-500 uppercase tracking-[0.18em]">Spread</p>
                            <p id="side-spread-value" class="text-[1.2rem] mt-2 font-mono font-black text-emerald-400 tracking-tight">0.00 USDT</p>
                            <p id="side-spread-meta" class="text-[9px] text-slate-500 uppercase font-black tracking-[0.14em] mt-1">0.00%</p>
                        </div>
                        <div class="grid min-w-[156px] grid-cols-2 gap-4 text-right">
                            <div>
                                <p class="text-[8px] font-black text-slate-500 uppercase tracking-[0.16em]">Prom/ciclo</p>
                                <p id="side-cycle-avg" class="mt-1.5 text-[15px] leading-none font-mono font-black text-white tracking-tight">0.00</p>
                                <p class="text-[9px] text-slate-400 font-black uppercase tracking-[0.14em] mt-1.5">USDT</p>
                            </div>
                            <div>
                                <p class="text-[8px] font-black text-slate-500 uppercase tracking-[0.16em]">Ciclos</p>
                                <p id="side-cycle-count" class="mt-1.5 text-[15px] leading-none font-mono font-black text-white tracking-tight">0</p>
                                <p class="text-[9px] text-slate-400 font-black uppercase tracking-[0.14em] mt-1.5">Totales</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex-1">
                <div class="flex items-center justify-between mb-4 border-b border-white/10 pb-2">
                    <p class="text-[12px] font-black text-gray-400 uppercase tracking-widest">Monitor Bancos</p>
                    <div class="flex items-center gap-2">
                        <button id="btn-clean-stale-ves" class="hidden text-[9px] font-black text-slate-300 hover:text-rose-300 bg-[#232a32] hover:bg-rose-500/10 border border-white/10 hover:border-rose-500/30 px-2 py-0.5 rounded cursor-pointer transition-all" title="Cerrar ciclos FIAT viejos sin parseo">Limpiar FIAT</button>
                    </div>
                </div>
                <div id="side-banks-list" class="space-y-4">
                    </div>
            </div>

            <div class="hidden">
                <div id="side-teorico"></div>
                <div id="side-binance"></div>
                <div id="side-discrepancia"></div>
                <div id="side-profit-total"></div>
            </div>
        </div>
    </aside>
</div>

<style>
    .custom-scroll::-webkit-scrollbar { width: 3px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #F3BA2F33; border-radius: 10px; }
    #sidebar-panel {
        height: calc(100dvh - 6.5rem);
        margin-top: 0.5rem;
    }
    .sidebar-panel-shell {
        pointer-events: none;
        border-left: 1px solid transparent;
        box-shadow: none;
        will-change: width;
    }
    .sidebar-panel-shell.is-open {
        pointer-events: auto;
        border-left-color: rgba(255, 255, 255, 0.1);
        box-shadow: -30px 0 80px rgba(0, 0, 0, 0.9);
    }
    .sidebar-close-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 999px;
        border: 1px solid rgba(243, 186, 47, 0.24);
        background: rgba(243, 186, 47, 0.1);
        color: #f3ba2f;
        font-size: 15px;
        transition: transform 160ms ease, background 160ms ease, border-color 160ms ease, color 160ms ease;
    }
    .sidebar-close-btn:hover {
        transform: scale(1.04);
        border-color: rgba(243, 186, 47, 0.5);
        background: rgba(243, 186, 47, 0.18);
        color: #fff3c2;
    }
    .sidebar-close-btn:focus-visible {
        outline: 2px solid rgba(243, 186, 47, 0.85);
        outline-offset: 3px;
    }

    @media (max-width: 767px) {
        .sidebar-auditor-shell {
            top: auto;
            right: 0;
            bottom: 0;
            width: 100%;
            align-items: flex-end;
            justify-content: flex-end;
        }

        #sidebar-trigger {
            position: fixed;
            left: 0.9rem;
            right: auto;
            bottom: calc(env(safe-area-inset-bottom, 0px) + 0.9rem);
            margin-top: 0;
            border-right: 2px solid rgba(243, 186, 47, 0.4);
            border-left-width: 2px;
            border-radius: 999px;
            padding: 0.88rem;
            box-shadow: 0 18px 36px rgba(0, 0, 0, 0.38);
            background: rgba(22, 26, 30, 0.96);
            z-index: 1102;
        }

        #sidebar-panel {
            position: fixed;
            inset: 0;
            height: 100dvh;
            margin: 0;
        }

        .sidebar-panel-shell {
            border-radius: 0;
            border-left: 0;
            background: rgba(18, 23, 29, 0.99);
        }

        .sidebar-panel-shell.is-open {
            box-shadow: none;
        }

        #sidebar-panel > div {
            padding: max(1rem, env(safe-area-inset-top, 0px)) 1rem calc(1.1rem + env(safe-area-inset-bottom, 0px));
        }
    }

    @media (min-width: 1024px) {
        #sidebar-panel {
            height: calc(100vh - 8rem);
            margin-top: 1rem;
        }
    }
</style>

<script>
    const trigger = document.getElementById('sidebar-trigger');
    const panel = document.getElementById('sidebar-panel');
    const closeBtn = document.getElementById('sidebar-close');
    const icon = document.getElementById('trigger-icon');
    let isOpen = false;

    const getPanelWidth = () => {
        const w = window.innerWidth || 0;
        if (w <= 768) return '100vw';
        if (w >= 1700) return '440px';
        if (w >= 1440) return '400px';
        if (w >= 1200) return '360px';
        return '320px';
    };

    const syncSidebarState = () => {
        if (!panel || !icon || !trigger) return;
        panel.style.width = isOpen ? getPanelWidth() : '0';
        panel.classList.toggle('is-open', isOpen);
        panel.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
        trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        icon.className = isOpen
            ? 'fas fa-times text-[#F3BA2F] text-[10px]'
            : 'fas fa-microchip text-[#F3BA2F] text-sm group-hover:rotate-12 transition-transform';
    };

    const setSidebarOpen = (open) => {
        isOpen = open;
        syncSidebarState();
    };

    trigger?.addEventListener('click', (e) => {
        e.stopPropagation();
        setSidebarOpen(!isOpen);
    });

    closeBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        setSidebarOpen(false);
    });

    document.addEventListener('click', (e) => {
        if (isOpen && !panel.contains(e.target) && !trigger.contains(e.target)) {
            setSidebarOpen(false);
        }
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) {
            setSidebarOpen(false);
        }
    });

    window.addEventListener('resize', () => {
        if (!isOpen) return;
        syncSidebarState();
    });

    // Ocultar para Inversores
    try {
        const userInfo = JSON.parse(sessionStorage.getItem('user_info') || '{}');
        if (userInfo.role === 'investor' || window.location.pathname.includes('investor')) {
            const container = trigger?.closest('.fixed');
            if (container) container.style.display = 'none';
        }
    } catch (e) {}
</script>
