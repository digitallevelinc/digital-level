---
// Sentinel - Sidebar Auditor Pro (Estructura Blindada)
---
<div class="fixed top-24 right-0 z-[1100] flex items-start pointer-events-none">
    
    <button 
        id="sidebar-trigger"
        class="pointer-events-auto mt-8 bg-[#161a1e] border-2 border-[#F3BA2F]/40 border-r-0 p-3.5 rounded-l-2xl shadow-[-10px_0_30px_rgba(243,186,47,0.2)] transition-all hover:scale-105 group border-l-[5px] border-l-[#F3BA2F]"
    >
        <i class="fas fa-microchip text-[#F3BA2F] text-sm group-hover:rotate-12 transition-transform" id="trigger-icon"></i>
        <div class="absolute inset-0 bg-gradient-to-r from-[#F3BA2F]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
    </button>

    <aside 
        id="sidebar-panel" 
        class="pointer-events-auto w-0 overflow-hidden bg-[#0b0e11]/98 backdrop-blur-3xl border-l border-white/10 transition-all duration-300 ease-in-out shadow-[-30px_0_80px_rgba(0,0,0,0.9)] rounded-l-[2rem]"
    >
        <div class="w-full pl-6 pr-8 py-6 h-full overflow-y-auto custom-scroll flex flex-col">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <p class="text-xs font-black text-[#F3BA2F] uppercase tracking-[0.2em]">Sentinel Auditor</p>
                    <p id="side-range-label" class="text-[11px] text-gray-500 uppercase font-bold tracking-widest mt-0.5">Rango Activo + Wallet Live</p>
                </div>
                
            </div>

            
            <div class="space-y-3 mb-8">
                <div class="bg-white/[0.03] p-4 rounded-2xl border border-white/8">
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <p id="side-ceiling-level-label" class="text-[10px] font-black text-rose-400 uppercase tracking-[0.18em]">Techo (Nivel)</p>
                            <p id="side-ceiling-level-value" class="text-[1.85rem] leading-none mt-2 font-black text-white tracking-tight">0.00</p>
                            <p id="side-ceiling-level-meta" class="text-[10px] text-gray-500 uppercase font-black tracking-[0.15em] mt-2">Sin data</p>
                        </div>
                        <span id="side-ceiling-level-badge" class="text-[9px] font-black text-white/70 bg-white/5 px-2 py-1 rounded-full uppercase tracking-[0.18em]">0 Bancos</span>
                    </div>
                </div>
                <div class="bg-[#101419] p-3 rounded-xl border border-white/6">
                    <p class="text-[9px] font-black text-slate-500 uppercase tracking-[0.18em]">Spread</p>
                    <p id="side-spread-value" class="text-[1.05rem] mt-2 font-mono font-black text-emerald-400 tracking-tight">0.00 USDT</p>
                    <p id="side-spread-meta" class="text-[9px] text-slate-500 uppercase font-black tracking-[0.14em] mt-1">0.00%</p>
                </div>
            </div>

            <div class="flex-1">
                <div class="flex items-center justify-between mb-4 border-b border-white/10 pb-2">
                    <p class="text-[11px] font-black text-gray-400 uppercase tracking-widest">Monitor Bancos</p>
                    <div class="flex items-center gap-2">
                        <span id="side-verdicts-count" class="text-[9px] font-black text-[#F3BA2F] bg-[#F3BA2F]/10 px-2 py-0.5 rounded">0 Open</span>
                    </div>
                </div>
                <div id="side-banks-list" class="space-y-3">
                    </div>
            </div>

            <div class="hidden">
                <div id="side-teorico"></div>
                <div id="side-binance"></div>
                <div id="side-discrepancia"></div>
                <div id="side-profit-total"></div>
            </div>
        </div>
    </aside>
</div>

<style>
    .custom-scroll::-webkit-scrollbar { width: 3px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #F3BA2F33; border-radius: 10px; }
    #sidebar-panel { height: calc(100vh - 8rem); margin-top: 1rem; }
</style>

<script>
    const trigger = document.getElementById('sidebar-trigger');
    const panel = document.getElementById('sidebar-panel');
    const icon = document.getElementById('trigger-icon');
    let isOpen = false;

    trigger?.addEventListener('click', (e) => {
        e.stopPropagation();
        isOpen = !isOpen;
        panel.style.width = isOpen ? '288px' : '0'; 
        icon.className = isOpen ? 'fas fa-times text-[#F3BA2F] text-[10px]' : 'fas fa-microchip text-[#F3BA2F] text-sm group-hover:rotate-12 transition-transform';
    });

    document.addEventListener('click', (e) => {
        if (isOpen && !panel.contains(e.target) && !trigger.contains(e.target)) {
            isOpen = false;
            panel.style.width = '0';
            icon.className = 'fas fa-microchip text-[#F3BA2F] text-sm group-hover:rotate-12 transition-transform';
        }
    });

    // Ocultar para Inversores
    try {
        const userInfo = JSON.parse(localStorage.getItem('user_info') || '{}');
        if (userInfo.role === 'investor' || window.location.pathname.includes('investor')) {
            const container = trigger?.closest('.fixed');
            if (container) container.style.display = 'none';
        }
    } catch (e) {}
</script>
