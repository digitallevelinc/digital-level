---
import CardHelp from './CardHelp.astro';
---
<div id="balance-module" class="overflow-hidden rounded-[1.6rem] border border-white/8 bg-[#0b0f14] shadow-[0_14px_36px_rgba(0,0,0,0.24)]">
    <div class="ledger-shell">
    <div class="ledger-hero px-4 py-4 md:px-5 md:py-5">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
            <div>
                <p class="ledger-kicker">Balance General</p>
            </div>
            <CardHelp
                title="Balance General"
                description="Lectura historica del extracto operativo, cargada bajo demanda."
                calculation="Cada fila clasifica solo flujos PAY y P2P. Se omiten RED, SWITCH y PARSEO."
                notes={[
                    "No bloquea la carga inicial del dashboard.",
                    "Scroll interno para listas largas.",
                    "Negativos en rojo y fiat como referencia secundaria.",
                    "Vista depurada para conciliacion directa de Binance Pay y P2P."
                ]}
                align="left"
            />
        </div>
    </div>

    <div id="balance-ledger-panel" class="ledger-panel">
        <div class="ledger-panel-head px-4 py-3 md:px-5">
            <div>
                <div class="ledger-panel-title">Transacciones</div>
                <div id="balance-ledger-count" class="ledger-panel-copy">Cargando historial...</div>
            </div>
            <div class="ledger-head-pills">
                <span id="balance-ledger-results" class="ledger-pill ledger-pill-primary">0 Resultados</span>
                <span id="balance-ledger-coverage-badge" class="ledger-pill ledger-pill-coverage" style="display:none">
                    <span class="ledger-pulse ledger-pulse-warning"></span>
                    <span id="balance-ledger-coverage-label">0 coberturas</span>
                    <div class="ledger-coverage-tooltip" id="balance-ledger-coverage-tooltip"></div>
                </span>
            </div>
        </div>

        <div class="border-t border-white/8 px-4 py-3 md:px-5">
            <div class="ledger-toolbar">
                <div class="flex flex-wrap items-center gap-2.5">
                    <span id="balance-ledger-page-indicator" class="ledger-page-indicator">
                        Pagina 0 / 0
                    </span>
                </div>

                <div class="ledger-toolbar-actions">
                    <div class="ledger-type-filters" role="group" aria-label="Filtrar ledger por tipo">
                        <button
                            id="balance-ledger-type-all"
                            type="button"
                            class="ledger-type-filter is-active"
                            data-ledger-type="ALL"
                        >
                            Todo
                        </button>
                        <button
                            id="balance-ledger-type-red"
                            type="button"
                            class="ledger-type-filter"
                            data-ledger-type="RED"
                        >
                            Red
                        </button>
                        <button
                            id="balance-ledger-type-p2p"
                            type="button"
                            class="ledger-type-filter"
                            data-ledger-type="P2P"
                        >
                            P2P
                        </button>
                        <button
                            id="balance-ledger-type-pay"
                            type="button"
                            class="ledger-type-filter"
                            data-ledger-type="PAY"
                        >
                            Pay
                        </button>
                    </div>

                    <label class="ledger-search-wrap">
                        <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-[#67e8f9]/70">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="11" cy="11" r="7"></circle>
                                <path d="m20 20-3.5-3.5"></path>
                            </svg>
                        </span>
                        <input
                            id="balance-ledger-search"
                            type="search"
                            placeholder="Buscar orden, referencia o descripcion..."
                            class="ledger-search-input"
                        />
                    </label>

                    <div class="ledger-nav">
                        <button
                            id="balance-ledger-prev"
                            type="button"
                            class="ledger-nav-btn"
                        >
                            Prev
                        </button>
                        <button
                            id="balance-ledger-next"
                            type="button"
                            class="ledger-nav-btn"
                        >
                            Next
                        </button>
                    </div>
                </div>
            </div>

            <div class="ledger-grid-head mt-3">
                <span>Fecha</span>
                <span>Descripcion</span>
                <span class="text-center">Tipo</span>
                <span class="text-right">Monto</span>
                <span class="text-right">Cobertura</span>
                <span class="text-right">Balance</span>
                <span class="text-right">Spread</span>
            </div>

            <div id="balance-ledger-scroll" class="custom-scrollbar ledger-scroll">
                <div id="balance-ledger-body" class="ledger-body">
                    <div class="px-4 py-10 text-center text-[15px] font-medium text-white md:px-6">
                        Cargando historial...
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
</div>

<style is:global>
    .ledger-shell {
        position: relative;
        background: #0b0f14;
    }

    .ledger-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        background: none;
        pointer-events: none;
    }

    .ledger-hero,
    .ledger-panel {
        position: relative;
        z-index: 1;
    }

    .ledger-kicker {
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: #F3BA2F;
    }

    .ledger-panel {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .ledger-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .ledger-panel-title {
        font-size: 0.86rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: white;
    }

    .ledger-panel-copy {
        margin-top: 0.35rem;
        font-size: 0.92rem;
        color: rgba(255, 255, 255, 0.96);
    }

    .ledger-head-pills {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.6rem;
    }

    .ledger-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.48rem;
        min-height: 38px;
        padding: 0.45rem 0.88rem;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .ledger-pill-primary {
        border: 1px solid rgba(56, 189, 248, 0.24);
        background: rgba(56, 189, 248, 0.12);
        color: #7dd3fc;
    }

    .ledger-pill-live {
        border: 1px solid rgba(34, 197, 94, 0.24);
        background: rgba(20, 83, 45, 0.32);
        color: #bbf7d0;
    }

    .ledger-pill-coverage {
        position: relative;
        border: 1px solid rgba(251, 191, 36, 0.3);
        background: rgba(120, 80, 0, 0.28);
        color: #fde68a;
        cursor: default;
    }

    .ledger-pulse {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: #34d399;
        box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.45);
        animation: ledger-pulse 2s infinite;
    }

    .ledger-pulse-warning {
        background: #fbbf24;
        box-shadow: 0 0 0 0 rgba(251, 191, 36, 0.45);
    }

    .ledger-coverage-tooltip {
        display: none;
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        z-index: 200;
        background: #0f1923;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 0.75rem;
        padding: 0.65rem 0.85rem;
        min-width: 240px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
        pointer-events: none;
        flex-direction: column;
        gap: 0.5rem;
    }

    .ledger-pill-coverage:hover .ledger-coverage-tooltip {
        display: flex;
    }

    .ledger-coverage-tooltip-item {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .ledger-coverage-tooltip-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .ledger-coverage-tooltip-name {
        font-size: 0.73rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.88);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ledger-coverage-tooltip-meta {
        display: flex;
        justify-content: space-between;
        font-size: 0.68rem;
        color: rgba(255, 255, 255, 0.5);
    }

    .ledger-coverage-tooltip-meta span:last-child {
        color: #fbbf24;
        font-weight: 600;
    }

    .ledger-toolbar {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
    }

    .ledger-page-indicator {
        font-size: 0.74rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: rgba(255, 255, 255, 0.96);
    }

    .ledger-toolbar-actions {
        display: grid;
        gap: 0.75rem;
        align-items: center;
    }

    @media (min-width: 768px) {
        .ledger-toolbar-actions {
            grid-template-columns: auto minmax(250px, 360px) auto;
            justify-content: space-between;
        }
    }

    .ledger-type-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .ledger-type-filter {
        min-height: 38px;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(15, 23, 42, 0.42);
        color: rgba(255, 255, 255, 0.72);
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        transition: all 0.18s ease;
    }

    .ledger-type-filter:hover {
        border-color: rgba(103, 232, 249, 0.24);
        color: rgba(255, 255, 255, 0.92);
    }

    .ledger-type-filter.is-active {
        border-color: rgba(103, 232, 249, 0.3);
        background: rgba(8, 145, 178, 0.16);
        color: #cffafe;
        box-shadow: inset 0 0 0 1px rgba(103, 232, 249, 0.08);
    }

    .ledger-search-wrap {
        position: relative;
        display: block;
    }

    .ledger-search-input {
        width: 100%;
        border-radius: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.04);
        padding: 0.85rem 0.9rem 0.85rem 2.4rem;
        font-size: 0.84rem;
        font-weight: 600;
        color: white;
        outline: none;
        transition: border-color 160ms ease, background 160ms ease, box-shadow 160ms ease;
    }

    .ledger-search-input::placeholder {
        color: rgba(255, 255, 255, 0.92);
    }

    .ledger-search-input:focus {
        border-color: rgba(243, 186, 47, 0.34);
        background: rgba(255, 255, 255, 0.07);
        box-shadow: 0 0 0 3px rgba(243, 186, 47, 0.12);
    }

    .ledger-nav {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .ledger-nav-btn {
        min-width: 88px;
        border-radius: 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.04);
        padding: 0.82rem 0.95rem;
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: rgba(255, 255, 255, 0.96);
        transition: all 160ms ease;
    }

    .ledger-nav-btn:hover {
        border-color: rgba(255, 255, 255, 0.22);
        color: white;
        background: rgba(255, 255, 255, 0.08);
    }

    .ledger-nav-btn:disabled {
        cursor: not-allowed;
        opacity: 1;
        color: rgba(255, 255, 255, 0.96);
    }

    .ledger-grid-head {
        display: none;
        grid-template-columns: 120px minmax(200px, 1.5fr) 80px minmax(120px, 0.9fr) minmax(150px, 1fr) minmax(120px, 0.9fr) minmax(120px, 0.9fr);
        gap: 0.75rem;
        border-block: 1px solid rgba(255, 255, 255, 0.08);
        padding: 0.9rem 0.75rem;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.96);
    }

    .ledger-scroll {
        max-height: 70dvh;
        overflow-y: auto;
        padding-right: 0.25rem;
    }

    @media (min-width: 1024px) {
        .ledger-scroll {
            max-height: 680px;
        }
    }

    .ledger-body {
        display: grid;
        gap: 0.85rem;
        padding: 0.9rem 0 0.2rem;
    }

    .ledger-row {
        position: relative;
        display: grid;
        gap: 1rem;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1.45rem;
        background: rgba(9, 13, 19, 0.94);
        padding: 1rem;
        box-shadow: 0 18px 36px rgba(0, 0, 0, 0.18);
        transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
    }

    .ledger-row::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: 4px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.16);
    }

    .ledger-row:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.16);
        box-shadow: 0 22px 42px rgba(0, 0, 0, 0.24);
        background: rgba(12, 17, 24, 0.98);
    }

    .ledger-row-p2p::before {
        background: #f3ba2f;
    }

    .ledger-row-p2p-sell::before {
        background: #ef4444;
    }

    .ledger-row-p2p-buy::before {
        background: #22c55e;
    }

    .ledger-row-pay::before {
        background: #38bdf8;
    }

    .ledger-row-liquid::before {
        background: #fb7185;
    }

    .ledger-row-parseo::before {
        background: #34d399;
    }

    .ledger-row-neutral::before {
        background: rgba(255, 255, 255, 0.28);
    }

    .ledger-metric-has-tooltip {
        position: relative;
        cursor: default;
    }

    .ledger-balance-tooltip {
        display: none;
        position: absolute;
        bottom: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%);
        z-index: 100;
        background: #0f1923;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 0.75rem;
        padding: 0.65rem 0.85rem;
        min-width: 220px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
        pointer-events: none;
    }

    .ledger-metric-has-tooltip:hover .ledger-balance-tooltip {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .ledger-balance-tooltip-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.72rem;
        color: rgba(255, 255, 255, 0.6);
        white-space: nowrap;
    }

    .ledger-balance-tooltip-row span:last-child {
        color: rgba(255, 255, 255, 0.92);
        font-weight: 600;
    }

    @media (min-width: 1024px) {
        .ledger-row {
            grid-template-columns: 120px minmax(200px, 1.5fr) 80px minmax(120px, 0.9fr) minmax(150px, 1fr) minmax(120px, 0.9fr) minmax(120px, 0.9fr);
            gap: 0.75rem;
            align-items: stretch;
            padding: 0.9rem 1rem;
            overflow: visible;
        }
    }

    .ledger-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 34px;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        border: 1px solid transparent;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .ledger-chip-p2p {
        background: rgba(243, 186, 47, 0.14);
        border-color: rgba(243, 186, 47, 0.3);
        color: #f7d774;
    }

    .ledger-chip-pay {
        background: rgba(56, 189, 248, 0.14);
        border-color: rgba(56, 189, 248, 0.3);
        color: #7dd3fc;
    }

    .ledger-chip-liquid {
        background: rgba(244, 63, 94, 0.14);
        border-color: rgba(244, 63, 94, 0.28);
        color: #fda4af;
    }

    .ledger-chip-red {
        background: rgba(168, 85, 247, 0.14);
        border-color: rgba(168, 85, 247, 0.28);
        color: #d8b4fe;
    }

    .ledger-chip-switch {
        background: rgba(34, 197, 94, 0.14);
        border-color: rgba(34, 197, 94, 0.28);
        color: #86efac;
    }

    .ledger-chip-parseo {
        background: rgba(249, 115, 22, 0.14);
        border-color: rgba(249, 115, 22, 0.28);
        color: #fdba74;
    }

    .ledger-chip-neutral {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.14);
        color: rgba(255, 255, 255, 0.72);
    }

    .ledger-mobile-date,
    .ledger-date-sub,
    .ledger-mobile-kicker,
    .ledger-subtitle,
    .ledger-metric-label,
    .ledger-metric-sub {
        font-size: 0.74rem;
        font-weight: 700;
        line-height: 1.45;
    }

    .ledger-mobile-date,
    .ledger-date-sub,
    .ledger-mobile-kicker,
    .ledger-subtitle {
        letter-spacing: 0.04em;
        color: rgba(255, 255, 255, 0.96);
        text-transform: uppercase;
    }

    .ledger-mobile-date {
        margin-top: 0.55rem;
    }

    .ledger-mobile-amount,
    .ledger-amount-main,
    .ledger-metric-value {
        font-size: 1.35rem;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.03em;
    }

    .ledger-mobile-sub,
    .ledger-amount-sub,
    .ledger-date-main,
    .ledger-title {
        font-size: 0.95rem;
        font-weight: 700;
        line-height: 1.4;
    }

    .ledger-mobile-title {
        margin-top: 0;
        font-size: 1rem;
        font-weight: 800;
        line-height: 1.35;
        color: white;
    }

    .ledger-mobile-card {
        display: grid;
        gap: 0.9rem;
        min-width: 0;
    }

    .ledger-desktop-row {
        display: none;
    }

    .ledger-mobile-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.8rem;
        align-items: start;
    }

    .ledger-mobile-badge-stack {
        min-width: 0;
    }

    .ledger-mobile-amount-block {
        display: grid;
        justify-items: end;
        gap: 0.28rem;
        min-width: 0;
        max-width: 44vw;
        text-align: right;
    }

    .ledger-mobile-kicker-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.55rem;
    }

    .ledger-mobile-kicker-text {
        flex: 1 1 180px;
        min-width: 0;
    }

    .ledger-mobile-kicker,
    .ledger-mobile-kicker-text {
        margin-top: 0;
    }

    .ledger-mobile-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 0;
    }

    .ledger-mobile-metrics {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: minmax(0, 1fr);
        margin-top: 0;
    }

    .ledger-date-col,
    .ledger-description-col,
    .ledger-type-col,
    .ledger-amount-col,
    .ledger-metric-col {
        min-width: 0;
    }

    .ledger-date-col {
        display: grid;
        align-content: start;
        gap: 0.38rem;
    }

    .ledger-date-main {
        color: rgba(255, 255, 255, 0.92);
    }

    .ledger-description-col {
        display: grid;
        align-content: start;
        gap: 0.55rem;
    }

    .ledger-title-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.6rem;
    }

    .ledger-title {
        color: white;
    }

    .ledger-order-badge {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0.32rem 0.7rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.08);
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.96);
    }

    .ledger-meta-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }

    .ledger-meta-chip {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        max-width: 100%;
        padding: 0.28rem 0.62rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.07);
        font-size: 0.68rem;
        font-weight: 700;
        line-height: 1.25;
        color: rgba(255, 255, 255, 0.96);
        overflow-wrap: anywhere;
    }

    .ledger-meta-chip-muted {
        color: rgba(255, 255, 255, 0.96);
    }

    .ledger-meta-chip-maker {
        background: rgba(243, 186, 47, 0.12);
        border-color: rgba(243, 186, 47, 0.35);
        color: #f3ba2f;
    }

    .ledger-meta-chip-taker {
        background: rgba(14, 203, 129, 0.12);
        border-color: rgba(14, 203, 129, 0.35);
        color: #0ecb81;
    }

    .ledger-type-col {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 0.1rem;
    }

    .ledger-amount-col {
        display: grid;
        align-content: start;
        justify-items: end;
        gap: 0.4rem;
        text-align: right;
    }

    .ledger-mobile-sub,
    .ledger-amount-sub {
        color: rgba(255, 255, 255, 0.96);
    }

    .ledger-metric-col {
        display: grid;
        align-content: stretch;
    }

    .ledger-metric-card {
        display: grid;
        gap: 0.35rem;
        min-height: 100%;
