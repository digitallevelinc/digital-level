---
// src/components/dashboard/operaciones.astro
import CardHelp from './CardHelp.astro';
---
<div class="group flex min-h-[250px] flex-col justify-between rounded-[1.4rem] border border-white/10 bg-[#161a1e] p-5 shadow-lg transition-all hover:border-blue-500/20 sm:p-6">
    <div>
        <div class="mb-3 flex items-start justify-between gap-3">
            <div class="flex items-center gap-2">
                <div class="p-2 bg-white/5 rounded-lg">
                    <i class="fas fa-microchip text-blue-400 text-xs"></i>
                </div>
                <p class="sentinel-label text-white !text-[12px] sm:!text-[13px] font-bold">Volumen de Operaciones</p>
            </div>
            <CardHelp
                title="Volumen de Operaciones"
                description="Resume cuantas transacciones movio el operador en el rango activo."
                calculation="Total de operaciones = compras P2P + ventas P2P. Los bloques PAY, RED y SWITCH muestran su conteo propio de entradas y salidas."
                notes={[
                    "Los conteos se actualizan al cambiar el filtro de fechas.",
                    "Sirve para validar carga operativa y consistencia entre modulos."
                ]}
                align="left"
            />
        </div>
        <h3 id="ops-total-count" class="sentinel-kpi-huge text-white mt-3">0</h3>
        <p class="mt-3 text-[11px] font-black uppercase tracking-[0.18em] text-white/60 sm:text-[12px]">Transacciones procesadas</p>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-3 border-t border-white/5 pt-4 sm:grid-cols-2">
        <div class="flex flex-col gap-1 rounded-xl border border-white/5 bg-black/20 p-3.5">
            <span class="sentinel-label !text-[11px] text-white/70">P2P (Ventas/Compras)</span>
            <span id="ops-p2p-counts" class="sentinel-value-md !text-[1.15rem] text-white tracking-normal">0/0</span>
        </div>
        
        <div class="flex flex-col gap-1 rounded-xl border border-white/5 bg-black/20 p-3.5">
            <span class="sentinel-label !text-[11px] text-white/70">PAY (D/R)</span>
            <span id="ops-pay-counts" class="sentinel-value-md !text-[1.15rem] text-white tracking-normal">0/0</span>
        </div>

        <div class="flex flex-col gap-1 rounded-xl border border-white/5 bg-black/20 p-3.5">
            <span class="sentinel-label !text-[11px] text-white/70">RED (D/R)</span>
            <span id="ops-red-counts" class="sentinel-value-md !text-[1.15rem] text-white tracking-normal">0/0</span>
        </div>

        <div class="flex flex-col gap-1 rounded-xl border border-white/5 bg-black/20 p-3.5">
            <span class="sentinel-label !text-[11px] text-white/70">SWT (Spot/Fondos)</span>
            <span id="ops-switch-counts" class="sentinel-value-md !text-[1.15rem] text-white tracking-normal">0/0</span>
        </div>
    </div>
</div>
