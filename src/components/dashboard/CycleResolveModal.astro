---
// CycleResolveModal.astro — Modal para resolver Bs. pendientes usando un ingreso alternativo (Pay/Red).
---

<dialog id="cycle-resolve-dialog" class="cycle-resolve-dialog" aria-labelledby="cycle-resolve-title">
  <div class="cycle-resolve-surface">
    <div class="cycle-resolve-head">
      <div>
        <p class="cycle-resolve-kicker">Cierre de ciclo</p>
        <h3 id="cycle-resolve-title" class="cycle-resolve-title">Resolver Bs. pendientes</h3>
      </div>
      <button type="button" id="cycle-resolve-close" class="cycle-resolve-close" aria-label="Cerrar modal">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>

    <div class="cycle-resolve-body">
      <p class="cycle-resolve-intro">
        Selecciona una transacción de ingreso (Pay/Red) que equivalga a los Bs. pendientes.
        El sistema aplicará la tasa que ingreses y cerrará los ciclos afectados.
      </p>

      <div class="cycle-resolve-pending" id="cycle-resolve-pending">
        <span>Bs. pendientes totales</span>
        <strong id="cycle-resolve-pending-value">0,00 Bs.</strong>
      </div>

      <form id="cycle-resolve-form" class="cycle-resolve-form">
        <label class="cycle-resolve-label">
          <span>Transacción de ingreso</span>
          <select id="cycle-resolve-transfer" name="transferId" required>
            <option value="">Cargando transferencias...</option>
          </select>
        </label>

        <label class="cycle-resolve-label">
          <span>Tasa de cambio (VES/USDT)</span>
          <input
            id="cycle-resolve-rate"
            name="manualRate"
            type="number"
            min="0.01"
            step="0.01"
            placeholder="Ej. 85.50"
            required
          />
        </label>

        <div class="cycle-resolve-preview" id="cycle-resolve-preview">
          <span>Equivalente</span>
          <strong id="cycle-resolve-preview-value">0,00 Bs.</strong>
        </div>

        <div class="cycle-resolve-actions">
          <button type="submit" id="cycle-resolve-submit">Salvar resolución</button>
          <button type="button" id="cycle-resolve-cancel" class="cycle-resolve-secondary">Cancelar</button>
        </div>
      </form>

      <div id="cycle-resolve-success" class="cycle-resolve-success hidden">
        <p>Resolución aplicada correctamente.</p>
        <button type="button" id="cycle-resolve-done" class="cycle-resolve-secondary">Cerrar</button>
      </div>

      <p id="cycle-resolve-error" class="cycle-resolve-error" role="alert"></p>
    </div>
  </div>
</dialog>

<style is:global>
  .cycle-resolve-dialog {
    width: min(520px, calc(100vw - 2rem));
    max-width: 520px;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
  }

  .cycle-resolve-dialog::backdrop {
    background: rgba(2, 6, 12, 0.76);
    backdrop-filter: blur(10px);
  }

  .cycle-resolve-dialog[open] {
    display: grid;
    place-items: center;
  }

  .cycle-resolve-surface {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.6rem;
    background: linear-gradient(180deg, rgba(12, 16, 22, 0.98), rgba(8, 11, 16, 0.98));
    box-shadow: 0 34px 80px rgba(0, 0, 0, 0.48);
    overflow: hidden;
  }

  .cycle-resolve-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cycle-resolve-kicker {
    color: rgba(255, 255, 255, 0.42);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .cycle-resolve-title {
    margin-top: 0.25rem;
    color: white;
    font-size: 1rem;
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .cycle-resolve-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.72);
    transition: transform 160ms ease, background 160ms ease;
  }

  .cycle-resolve-close:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
  }

  .cycle-resolve-close svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.2;
  }

  .cycle-resolve-body {
    padding: 1.25rem;
  }

  .cycle-resolve-intro {
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.88rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .cycle-resolve-pending {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-radius: 1rem;
    background: rgba(251, 146, 60, 0.1);
    border: 1px solid rgba(251, 146, 60, 0.25);
    padding: 1rem 1.1rem;
    margin-bottom: 1rem;
  }

  .cycle-resolve-pending span {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cycle-resolve-pending strong {
    color: #fdba74;
    font-size: 1.05rem;
    font-weight: 950;
  }

  .cycle-resolve-form {
    display: grid;
    gap: 0.9rem;
  }

  .cycle-resolve-label {
    display: grid;
    gap: 0.35rem;
  }

  .cycle-resolve-label > span {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cycle-resolve-label input,
  .cycle-resolve-label select {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.8rem;
    background: #05070a;
    color: white;
    outline: none;
    padding: 0.78rem 0.85rem;
    font-size: 0.9rem;
    transition: border-color 160ms ease, background 160ms ease;
  }

  .cycle-resolve-label input:focus,
  .cycle-resolve-label select:focus {
    border-color: rgba(243, 186, 47, 0.72);
    background: rgba(255, 255, 255, 0.04);
  }

  .cycle-resolve-label select option {
    background: #0c1016;
    color: white;
  }

  .cycle-resolve-preview {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-radius: 0.8rem;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.8rem 1rem;
  }

  .cycle-resolve-preview span {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.68rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cycle-resolve-preview strong {
    color: #f3ba2f;
    font-size: 1rem;
    font-weight: 950;
  }

  .cycle-resolve-actions {
    display: flex;
    gap: 0.65rem;
    margin-top: 0.3rem;
  }

  .cycle-resolve-actions button,
  .cycle-resolve-secondary {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    padding: 0.72rem 0.9rem;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: transform 160ms ease, opacity 160ms ease, background 160ms ease, border-color 160ms ease;
  }

  .cycle-resolve-secondary {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.72);
  }

  #cycle-resolve-submit {
    flex: 1;
    border-color: rgba(243, 186, 47, 0.9);
    background: #f3ba2f;
    color: black;
  }

  .cycle-resolve-actions button:active,
  .cycle-resolve-secondary:active {
    transform: scale(0.98);
  }

  .cycle-resolve-error {
    min-height: 1rem;
    color: #fb7185;
    font-size: 0.78rem;
    font-weight: 800;
    margin-top: 0.75rem;
  }

  .cycle-resolve-success {
    text-align: center;
    padding: 1.5rem 0;
  }

  .cycle-resolve-success p {
    color: #86efac;
    font-size: 0.95rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .hidden {
    display: none !important;
  }

  @media (max-width: 640px) {
    .cycle-resolve-dialog {
      width: calc(100vw - 0.5rem);
      margin: 0.25rem;
    }

    .cycle-resolve-actions {
      flex-direction: column;
    }
  }
</style>
