---
// src/components/dashboard/ComisionOperador.astro
import CardHelp from './CardHelp.astro';
---
<div class="group relative overflow-hidden rounded-[1.4rem] border border-[#F3BA2F]/20 bg-[#161a1e] p-5 shadow-xl transition-all hover:border-[#F3BA2F]/40 sm:p-6">
  <div class="absolute -right-4 -top-4 w-20 h-20 bg-[#F3BA2F]/5 rounded-full blur-2xl group-hover:bg-[#F3BA2F]/10 transition-all"></div>

  <div class="mb-6 flex items-start justify-between gap-4">
    <div class="z-10">
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 rounded-full bg-[#F3BA2F] shadow-[0_0_8px_#F3BA2F]"></div>
        <span class="text-[12px] font-black uppercase tracking-[0.18em] text-white-400 sm:text-[13px]">Payroll Operativo</span>
      </div>
      <div class="flex items-center gap-2 mt-2">
        <span id="op-config-pct" class="rounded-lg border border-[#F3BA2F]/20 bg-[#F3BA2F]/10 px-2.5 py-1 font-mono text-[24px] font-black text-[#F3BA2F] sm:text-[26px]">--%</span>
        <span class="text-[11px] text-white-500 uppercase font-black tracking-[0.16em]">Profit Share</span>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <CardHelp
        title="Payroll Operativo"
        description="Muestra el acumulado disponible para el operador en el periodo."
        calculation="Monto disponible = participacion configurada sobre profit neto elegible del periodo. Los retiros registrados descuentan ese acumulado."
        notes={[
          "El porcentaje se define en configuracion de operador.",
          "La seccion de retiro por orden mantiene trazabilidad."
        ]}
      />
      <div class="rounded-lg border border-white/5 bg-white/5 p-2.5">
          <i class="fas fa-hand-holding-dollar text-[#F3BA2F] text-sm"></i>
      </div>
    </div>
  </div>

  <div class="relative z-10 space-y-5">
    <div>
      <div class="flex items-baseline gap-1">
        <span class="font-mono text-[2rem] font-black tracking-tight text-white sm:text-[2.2rem]" id="op-net-profit">0.00</span>
        <span class="text-[11px] font-black uppercase text-[#F3BA2F]">usdt</span>
      </div>
      <div class="mt-2 text-[11px] font-bold uppercase tracking-[0.16em] text-white-500">Acumulado disponible</div>
    </div>

    <!-- Registro de Retiro por Numero de Orden (Auditoria) -->
      <div class="border-t border-white/5 pt-4">
      <div class="flex items-center justify-between gap-3">
        <div class="text-[10px] font-black uppercase tracking-[0.18em] text-white-500">Retiro por Orden</div>
        <div class="text-[10px] font-black uppercase tracking-[0.18em] text-white-600">Descuenta Profit Share</div>
      </div>

      <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-[1fr_auto] sm:items-center">
        <div class="relative">
          <input
            id="payroll-withdrawal-order"
            inputmode="text"
            autocomplete="off"
            placeholder="Pega ORD, Binance ID, TxHash o ID local..."
            class="w-full rounded-lg border border-white/10 bg-black/25 px-3 py-3 text-[13px] font-mono font-black text-white placeholder:text-white/25 transition-colors focus:border-[#F3BA2F]/45 focus:bg-black/35 focus:outline-none sm:text-[14px]"
          />
          <div class="absolute right-3 top-1/2 -translate-y-1/2 select-none text-[11px] font-black text-white/20">#</div>
        </div>
        <button
          id="payroll-withdrawal-save"
          class="h-[44px] shrink-0 rounded-lg border border-[#F3BA2F]/25 bg-[#F3BA2F]/10 px-4 text-[11px] font-black uppercase tracking-[0.18em] text-[#F3BA2F] transition-all hover:border-[#F3BA2F]/45 hover:bg-[#F3BA2F]/15 sm:h-[48px]"
        >
          Agregar
        </button>
      </div>

      <div class="mt-2 text-[10px] font-bold uppercase tracking-[0.16em] text-white-600 opacity-70">
        Acepta P2P_SELL, PAY_SENT o RETIRO RED en SUCCESS
      </div>

      <div id="payroll-withdrawal-feedback" class="mt-2 hidden"></div>
      <div class="mt-3 space-y-2 max-h-44 overflow-auto pr-1" id="payroll-withdrawal-log"></div>
    </div>
  </div>

  <div class="mt-2 flex items-center justify-between opacity-50">
    <span class="text-[11px] font-bold text-white-500 uppercase">Calculado sobre Profit Neto</span>
    <i class="fas fa-shield-check text-[10px] text-white-600"></i>
  </div>
</div>
