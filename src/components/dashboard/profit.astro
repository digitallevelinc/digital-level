---
import CardHelp from './CardHelp.astro';
---
<div id="profit-card" class="flex flex-col gap-5 rounded-[1.5rem] border border-emerald-500/20 bg-[#161a1e] p-5 shadow-2xl sm:p-6 lg:p-7">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <p class="text-[12px] font-black uppercase tracking-[0.22em] text-white/70 sm:text-[13px]">Resumen de Profit</p>
    <CardHelp
      title="Resumen de Profit"
      description="Card principal de rendimiento del periodo seleccionado."
      calculation="Wallet real = saldo verificado por API. Profit Operativo = suma directa de los SPREADS del ledger para el rango seleccionado (sin fallback, sin restar fees de venta)."
      notes={[
        "Se priorizan metricas operativas que no dupliquen Balance General.",
        "El wallet real se mantiene como referencia viva del saldo verificado.",
        "Caja neta y profit dispersor solo aplican cuando el backend detecta contexto de dispersor."
      ]}
      align="left"
    />
  </div>

  <div class="grid grid-cols-1 gap-3 border-t border-white/5 pt-5 sm:grid-cols-2 md:grid-cols-4">
    <div class="flex min-h-[132px] items-start gap-4 rounded-xl border border-emerald-500/20 bg-emerald-500/[0.07] p-4 shadow-inner shadow-black/20">
      <div class="rounded-lg bg-emerald-500/10 p-3 text-emerald-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 7.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-1.5"></path><path d="M16 12h6"></path><path d="M19 9l3 3-3 3"></path></svg>
      </div>
      <div class="flex-1">
        <p class="mb-1 text-[11px] font-black uppercase tracking-[0.16em] text-white/55 sm:text-[12px]">Binance Wallet (API)</p>
        <h4 id="real-binance-balance" class="font-mono text-[1.75rem] font-bold leading-tight text-emerald-400 sm:text-[1.95rem]">---</h4>
        <p class="mt-2 text-[10px] italic uppercase tracking-[0.14em] text-white/45 sm:text-[11px]">Saldo real verificado</p>
      </div>
    </div>

    <div class="flex min-h-[132px] items-start gap-4 rounded-xl border border-white/5 bg-white/[0.02] p-4 shadow-inner shadow-black/20">
      <div class="rounded-lg bg-blue-500/10 p-3 text-blue-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
      </div>
      <div class="flex-1">
        <div class="mb-1 flex items-center gap-2">
          <p class="text-[11px] font-black uppercase tracking-[0.16em] text-white/55 sm:text-[12px]">Profit Operativo</p>
          <div
            class="card-help"
            data-card-help
            data-open="false"
            onclick="event.stopPropagation()"
          >
            <button
              type="button"
              class="card-help-trigger"
              aria-label="Ayuda: Profit Operativo"
              aria-expanded="false"
            >
              ?
            </button>
            <div class="card-help-popover" role="tooltip">
              <p class="card-help-title">Profit Operativo</p>
              <p class="card-help-text" id="audit-profit-tooltip-summary">
                Suma directa de los SPREADS del ledger para el rango actual.
              </p>
              <p class="card-help-calc" id="audit-profit-tooltip-formula">
                <strong>Regla:</strong> Profit Operativo = Σ SPREADS del rango.
              </p>
              <div class="mt-3 rounded-lg border border-white/10 bg-black/20 px-3 py-2">
                <p class="text-[10px] font-black uppercase tracking-[0.14em] text-[#F3BA2F]">Operacion visible</p>
                <p id="audit-profit-tooltip-operation" class="mt-1 font-mono text-[13px] font-bold leading-[1.5] text-white/90">
                  --- = ---
                </p>
              </div>
              <div class="mt-3 rounded-lg border border-white/10 bg-black/20 px-3 py-2">
                <p class="text-[10px] font-black uppercase tracking-[0.14em] text-[#F3BA2F]">Origen del spread</p>
                <p id="audit-profit-tooltip-spread-breakdown" class="mt-1 font-mono text-[12px] font-bold leading-[1.6] text-white/80">
                  ---
                </p>
              </div>
              <div class="mt-3 space-y-2 text-[13px] leading-[1.45] text-white/80">
                <div class="flex items-center justify-between gap-3">
                  <span class="text-white/55">Resultado mostrado</span>
                  <span id="audit-profit-tooltip-result" class="font-mono font-bold text-emerald-400">---</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span id="audit-profit-tooltip-source-label" class="text-white/55">Spread ledger</span>
                  <span id="audit-profit-tooltip-source-value" class="font-mono text-white/90">---</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span class="text-white/55">Profit canonico backend</span>
                  <span id="audit-profit-tooltip-backend" class="font-mono text-white/90">---</span>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <span class="text-white/55">Fees de venta</span>
                  <span id="audit-profit-tooltip-sell-fees" class="font-mono text-rose-300">---</span>
                </div>
                <div class="flex items-center justify-between gap-3 border-t border-white/10 pt-2">
                  <span class="text-white/55">Fallback visual</span>
                  <span id="audit-profit-tooltip-fallback" class="font-mono text-white/90">---</span>
                </div>
              </div>
              <p class="mt-3 text-[12px] leading-[1.45] text-white/60" id="audit-profit-tooltip-note">
                Si el backend envia el profit canonico, ese valor manda. Si no, este KPI no debe reconstruirse con otras fuentes.
              </p>
            </div>
          </div>
        </div>
        <div class="mt-1 min-h-[2.35rem] sm:min-h-[2.6rem]">
          <div
            id="audit-total-profit-skeleton"
            class="hidden h-[2.05rem] w-32 animate-pulse rounded-md bg-white/10 shadow-inner shadow-black/20 sm:h-[2.25rem] sm:w-36"
            aria-hidden="true"
          ></div>
          <h4 id="audit-total-profit-display" class="font-mono text-[1.75rem] font-bold leading-tight text-white sm:text-[1.95rem]">---</h4>
        </div>
        <p class="mt-2 text-[10px] italic uppercase tracking-[0.14em] text-white/45 sm:text-[11px]">Suma de SPREADS del rango</p>
      </div>
    </div>

    <div class="flex min-h-[132px] items-start gap-4 rounded-xl border border-white/5 bg-white/[0.02] p-4 shadow-inner shadow-black/20">
      <div class="rounded-lg bg-purple-500/10 p-3 text-purple-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
      </div>
      <div class="flex-1">
        <p class="mb-1 text-[11px] font-black uppercase tracking-[0.16em] text-white/55 sm:text-[12px]">Volumen Total</p>
        <h4 id="audit-total-volume" class="font-mono text-[1.75rem] font-bold leading-tight text-white sm:text-[1.95rem]">---</h4>
        <p class="mt-2 text-[10px] italic uppercase tracking-[0.14em] text-white/45 sm:text-[11px]">USDT operados</p>
      </div>
    </div>

    <div id="capital-control-card" class="capital-control-card flex min-h-[132px] items-start gap-4 rounded-xl p-4 shadow-inner shadow-black/20">
      <div class="rounded-lg bg-orange-500/10 p-3 text-orange-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
      </div>
      <div class="flex-1">
        <div class="mb-1 flex items-center justify-between gap-2">
          <p class="text-[11px] font-black uppercase tracking-[0.16em] text-white/55 sm:text-[12px]">Cobertura</p>
          <span id="capital-control-status" class="capital-control-status">NORMAL</span>
        </div>
        <div class="flex items-baseline gap-1.5">
          <span id="capital-control-fiat" class="font-mono text-[1.75rem] font-bold leading-tight text-white sm:text-[1.95rem]">0,00</span>
          <span class="text-[12px] font-bold uppercase text-white/55">Bs.</span>
        </div>
        <div id="capital-control-usdt" class="mt-1 text-[10px] italic uppercase tracking-[0.14em] text-white/45 sm:text-[11px]">≈ 0,00 USDT</div>
        <div class="capital-control-bar mt-2">
          <div id="capital-control-bar-consumed" class="capital-control-bar-consumed" style="width: 0%"></div>
          <div id="capital-control-bar-pending" class="capital-control-bar-pending" style="width: 100%"></div>
        </div>
        <div class="capital-control-meta mt-2">
          <span>Salido: <strong id="capital-control-expected">0,00 Bs.</strong></span>
          <span>Retornado: <strong id="capital-control-consumed">0,00 Bs.</strong></span>
        </div>
      </div>
    </div>
  </div>

  <div class="rounded-xl border border-white/5 bg-white/[0.02] p-4 shadow-inner sm:p-5">
    <button id="toggle-evolution-chart" type="button" class="w-full flex items-center justify-between cursor-pointer bg-transparent border-0 p-0 group">
      <h3 class="text-[13px] font-bold uppercase tracking-[0.14em] text-white/70 sm:text-sm group-hover:text-white/90 transition-colors">Evolucion Historica</h3>
      <i id="evolution-chart-icon" class="fas fa-chevron-right text-white/40 text-xs transition-transform duration-300 group-hover:text-white/60"></i>
    </button>
    <div id="evolution-chart-body" class="hidden mt-4">
      <div class="relative h-72 w-full sm:h-80">
        <canvas id="profit-chart"></canvas>
      </div>
    </div>
  </div>
</div>

<style is:global>
  #profit-card .capital-control-card {
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid rgba(251, 146, 60, 0.35);
    background: linear-gradient(180deg, rgba(251, 146, 60, 0.10) 0%, rgba(67, 24, 8, 0.35) 100%);
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  #profit-card .capital-control-card.is-zero {
    border-color: rgba(34, 197, 94, 0.35);
    background: linear-gradient(180deg, rgba(34, 197, 94, 0.08) 0%, rgba(6, 30, 22, 0.30) 100%);
  }
  #profit-card .capital-control-card.is-critical {
    border-color: rgba(244, 63, 94, 0.40);
    background: linear-gradient(180deg, rgba(244, 63, 94, 0.12) 0%, rgba(61, 22, 31, 0.35) 100%);
  }
  #profit-card .capital-control-status {
    border-radius: 999px;
    padding: 0.25rem 0.55rem;
    font-size: 0.6rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: rgba(251, 146, 60, 0.14);
    color: #fdba74;
  }
  #profit-card .capital-control-card.is-zero .capital-control-status {
    background: rgba(34, 197, 94, 0.14);
    color: #86efac;
  }
  #profit-card .capital-control-card.is-critical .capital-control-status {
    background: rgba(244, 63, 94, 0.14);
    color: #fda4af;
  }
  #profit-card .capital-control-card.is-zero #capital-control-usdt {
    color: #86efac;
  }
  #profit-card .capital-control-bar {
    height: 5px;
    width: 100%;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    overflow: hidden;
    display: flex;
  }
  #profit-card .capital-control-bar-consumed {
    height: 100%;
    background: linear-gradient(90deg, #34d399, #22c55e);
    border-radius: 3px 0 0 3px;
    transition: width 0.4s ease;
  }
  #profit-card .capital-control-bar-pending {
    height: 100%;
    background: linear-gradient(90deg, #f97316, #fbbf24);
    border-radius: 0 3px 3px 0;
    transition: width 0.4s ease;
  }
  #profit-card .capital-control-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.55);
  }
  #profit-card .capital-control-meta strong {
    color: rgba(255, 255, 255, 0.85);
  }
  @media (max-width: 639px) {
    #profit-card .capital-control-card {
      padding: 0.85rem 1rem;
    }
    #profit-card .capital-control-meta {
      flex-direction: column;
      gap: 0.15rem;
    }
  }
</style>
