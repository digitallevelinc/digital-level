---
import CardHelp from './CardHelp.astro';
---
<div class="flex flex-col gap-6 rounded-[1.5rem] border border-emerald-500/20 bg-[#161a1e] p-5 shadow-2xl sm:p-6 lg:p-7">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <p class="text-[12px] font-black uppercase tracking-[0.22em] text-white/70 sm:text-[13px]">Resumen de Profit</p>
    <CardHelp
      title="Resumen de Profit"
      description="Card principal de rendimiento del periodo seleccionado."
      calculation="Wallet real = saldo verificado por API. Profit generado = suma del profit neto consolidado por banco en el rango. Volumen total = suma USDT operada."
      notes={[
        "Se priorizan metricas operativas que no dupliquen Balance General.",
        "El wallet real se mantiene como referencia viva del saldo verificado."
      ]}
      align="left"
    />
  </div>

  <div class="grid grid-cols-1 gap-5">
    <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/5 p-5">
      <span class="mb-2 block text-center text-[12px] font-black uppercase text-white-500/60 sm:text-[13px]">Binance Wallet (API)</span>
      <div id="real-binance-balance" class="text-center font-mono text-[2rem] font-bold leading-none text-emerald-400 sm:text-[2.3rem]">---</div>
      <p class="mt-3 text-center text-[11px] font-bold uppercase tracking-[0.14em] text-white-600">Saldo real verificado</p>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-4 border-t border-white/5 pt-6 md:grid-cols-2">
    <div class="flex items-center gap-4 rounded-xl border border-white/5 bg-white/[0.02] p-5 shadow-inner">
      <div class="rounded-lg bg-blue-500/10 p-3 text-blue-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
      </div>
      <div>
        <p class="mb-1 text-[12px] font-black uppercase tracking-[0.16em] text-white-400 sm:text-[13px]">Profit Generado Real</p>
        <h4 id="audit-total-profit-display" class="font-mono text-[1.8rem] font-bold leading-tight text-white sm:text-[2rem]">---</h4>
        <p class="mt-1 text-[11px] italic uppercase tracking-[0.12em] text-white-500">Suma de profit neto consolidado del rango</p>
      </div>
    </div>

    <div class="flex items-center gap-4 rounded-xl border border-white/5 bg-white/[0.02] p-5 shadow-inner">
      <div class="rounded-lg bg-purple-500/10 p-3 text-purple-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
      </div>
      <div class="flex-1">
        <p class="mb-1 text-[12px] font-black uppercase tracking-[0.16em] text-white-400 sm:text-[13px]">Volumen Total</p>
        <h4 id="audit-total-volume" class="font-mono text-[1.8rem] font-bold leading-tight text-white sm:text-[2rem]">---</h4>
        <div class="mt-1 flex items-center justify-between">
          <p class="text-[11px] italic uppercase tracking-[0.12em] text-white-500">USDT Operados</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-2 rounded-xl border border-white/5 bg-white/[0.02] p-4 shadow-inner sm:p-5">
    <div class="mb-4 flex items-center justify-between">
      <h3 class="text-[13px] font-bold uppercase tracking-[0.14em] text-white/70 sm:text-sm">Evolucion Historica</h3>
    </div>
    <div class="relative h-72 w-full sm:h-80">
      <canvas id="profit-chart"></canvas>
    </div>
  </div>
</div>
