---
import '../styles/global.css';
import SidebarMonitor from '../components/dashboard/SidebarMonitor.astro';
---
<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <link rel="icon" type="image/png" href="/img/logo.png" />
        <title>Dashboard | Digital Level</title>
        <!-- Google Fonts: Poppins -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    </head>
    <body class="bg-[#0b0e11] text-white min-h-screen font-sans selection:bg-[#F3BA2F]/30 overflow-x-hidden antialiased">
        
        <header class="sticky top-0 z-50 border-b border-gray-800/50 bg-[#0b0e11]/88 px-4 py-3 backdrop-blur-md md:px-8 md:py-4">
            <div class="mx-auto flex w-full max-w-[1680px] items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <img src="/img/logo.png" class="w-8 h-8 md:w-10 md:h-10 object-contain" alt="Logo" />
                    <div class="flex flex-col">
                        <span class="text-[#F3BA2F] font-black text-sm md:text-base tracking-[0.2em] uppercase italic leading-none">
                            DIGITAL LEVEL
                        </span>
                        <span class="mt-1 hidden text-[11px] text-white-500 uppercase font-bold tracking-widest md:block">
                            Sentinel Core v2.0
                        </span>
                    </div>
                </div>
                <div class="flex items-center gap-2 sm:gap-3">
                    <!-- Notificaciones -->
                    <div id="dashboard-notifications" class="relative">
                        <button
                            id="dashboard-notifications-btn"
                            type="button"
                            aria-expanded="false"
                            aria-controls="dashboard-notifications-panel"
                            class="group relative flex h-10 w-10 items-center justify-center rounded-xl border border-[#F3BA2F]/20 bg-[#F3BA2F]/10 text-[#F3BA2F] shadow-lg transition-all duration-300 hover:border-[#F3BA2F]/50 hover:bg-[#F3BA2F]/20 sm:h-11 sm:w-11"
                            title="Alertas operativas"
                        >
                            <i class="fas fa-bell text-sm transition-transform group-hover:scale-110"></i>
                            <span id="dashboard-notifications-badge" class="hidden absolute -right-1 -top-1 min-w-[1.25rem] rounded-full bg-rose-500 px-1.5 py-0.5 text-[10px] font-black text-white shadow-lg shadow-rose-500/30">0</span>
                        </button>
                        <div
                            id="dashboard-notifications-panel"
                            class="hidden fixed inset-x-3 top-[5.4rem] z-[1200] max-h-[calc(100dvh-6.4rem)] overflow-hidden rounded-[1.35rem] border border-white/10 bg-[#11161c]/95 shadow-[0_24px_60px_rgba(0,0,0,0.55)] backdrop-blur-xl md:absolute md:inset-x-auto md:right-0 md:top-[calc(100%+0.75rem)] md:w-[min(420px,calc(100vw-1.5rem))] md:max-h-none"
                        >
                            <div class="flex flex-col gap-3 px-4 pt-4 sm:flex-row sm:items-center sm:justify-between">
                                <div>
                                    <p class="text-[10px] font-black uppercase tracking-[0.2em] text-[#F3BA2F]">Inbox</p>
                                    <p class="mt-1 text-sm font-black uppercase tracking-[0.14em] text-white">Alertas</p>
                                </div>
                                <div class="grid grid-cols-2 gap-2 sm:flex sm:gap-2">
                                    <button id="dashboard-notifications-send-note" type="button" class="w-full rounded-full border border-blue-500/20 bg-blue-500/10 px-3 py-2 text-[10px] font-black uppercase tracking-[0.14em] text-blue-400 transition-colors hover:border-blue-400/40 hover:text-blue-300">Enviar nota</button>
                                    <button id="dashboard-notifications-mark-read" type="button" class="w-full rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-[10px] font-black uppercase tracking-[0.14em] text-white/70 transition-colors hover:border-[#F3BA2F]/40 hover:text-[#F3BA2F]">Marcar todo</button>
                                </div>
                            </div>
                            <div class="px-4 mt-2 flex gap-4 border-b border-white/10 pt-2">
                                <button id="dashboard-notifications-tab-unread" class="pb-2 text-[11px] font-black uppercase tracking-[0.14em] text-[#F3BA2F] border-b-[2px] border-[#F3BA2F] transition-colors relative">No Leidos</button>
                                <button id="dashboard-notifications-tab-read" class="pb-2 text-[11px] font-black uppercase tracking-[0.14em] text-white/40 border-b-[2px] border-transparent transition-colors hover:text-white/70 relative">Leidos</button>
                            </div>
                            <div id="dashboard-notifications-list" class="max-h-[calc(100dvh-12rem)] space-y-3 overflow-x-hidden overflow-y-auto overscroll-contain p-3 [scrollbar-gutter:stable] md:max-h-[360px]" style="-webkit-overflow-scrolling: touch; touch-action: pan-y;">
                                <div class="px-4 py-5 text-center text-sm font-bold text-white/50">Sin notificaciones por ahora.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Exportar Excel -->
                    <a
                        id="link-p2p-sheet"
                        href="#"
                        class="group flex h-10 w-10 items-center justify-center rounded-xl border border-emerald-500/10 bg-emerald-500/5 text-emerald-500 shadow-lg transition-all duration-300 hover:border-emerald-500/40 hover:bg-emerald-500/20 sm:h-11 sm:w-11"
                        title="Exportar rango a Excel"
                        onclick="return false;"
                    >
                        <svg class="w-5 h-5 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2zM19 20H5V4h8v4h6v12zM7 18h10v-2H7v2zm0-4h10v-2H7v2zm0-4h10V8H7v2z" />
                        </svg>
                    </a>

                    <!-- Cerrar Sesión -->
                    <button
                        id="logout-btn"
                        class="h-10 rounded-xl border border-red-500/10 bg-red-500/5 px-3 text-[10px] font-black uppercase tracking-[0.14em] text-red-500 shadow-lg transition-all duration-300 hover:border-red-500/40 hover:bg-red-500/20 active:scale-95 sm:h-11 sm:px-4 sm:text-[11px] sm:tracking-[0.16em]"
                    >
                        Cerrar Sesion
                    </button>
                </div>
            </div>
        </header>

        <SidebarMonitor />

        <main class="w-full px-3 pt-4 pb-0 transition-all duration-500 sm:px-4 sm:pt-5 sm:pb-0 md:px-8 md:pt-8 md:pb-0 lg:px-10 lg:pt-10 lg:pb-0">
            <div class="mx-auto w-full max-w-[1680px]">
                <slot />
            </div>
        </main>

        <footer class="w-full border-t border-gray-900 px-4 py-3 text-center md:px-8">
            <p class="text-[10px] text-white/72 font-medium uppercase tracking-[0.22em] font-mono">
            &copy; <span id="year"></span> DIGITAL LEVEL Sentinel System
        </p>

        <script>
            document.getElementById('year').textContent = new Date().getFullYear();
        </script>
        </footer>
    </body>
</html>

<style is:global>
    :root {
        --font-sans: 'Poppins', system-ui, -apple-system, sans-serif;
    }
    body {
        font-family: var(--font-sans);
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    .font-mono {
        font-family: var(--font-sans) !important;
        font-variant-numeric: tabular-nums;
    }

    /* Sistema de tipografia mejorado */
    .sentinel-title { @apply text-[16px] sm:text-[18px] font-black uppercase italic tracking-[0.12em] text-white leading-tight; }
    .sentinel-label { @apply text-[12px] sm:text-[13px] text-gray-400 uppercase font-black tracking-[0.16em]; }
    .sentinel-value-md { @apply text-[16px] sm:text-[18px] font-bold text-white tracking-tight leading-tight; }
    .sentinel-value-lg { @apply text-[22px] sm:text-[24px] font-bold text-white tracking-tight leading-tight; }
    .sentinel-kpi-huge { @apply text-[2.4rem] sm:text-[2.85rem] lg:text-[3.2rem] font-black text-emerald-400 tracking-tight leading-none; }

    .card-help {
        position: relative;
        display: inline-flex;
        align-items: center;
        z-index: 30;
    }

    .card-help-trigger {
        width: 22px;
        height: 22px;
        border-radius: 999px;
        border: 1px solid rgba(243, 186, 47, 0.35);
        background: rgba(243, 186, 47, 0.12);
        color: #f3ba2f;
        font-size: 14px;
        font-weight: 900;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .card-help-trigger:hover {
        border-color: rgba(243, 186, 47, 0.8);
        background: rgba(243, 186, 47, 0.25);
    }

    .card-help-popover {
        position: fixed;
        top: 0;
        left: 0;
        width: min(420px, calc(100vw - 20px));
        border: 1px solid rgba(243, 186, 47, 0.25);
        border-radius: 14px;
        background: rgba(11, 14, 17, 0.98);
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.55);
        padding: 14px 16px;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(-4px);
        transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
        z-index: 1500;
    }

    .card-help:hover .card-help-popover,
    .card-help:focus-within .card-help-popover,
    .card-help[data-open='true'] .card-help-popover {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0);
    }

    .card-help[data-open='true'] .card-help-trigger {
        border-color: rgba(243, 186, 47, 0.9);
        background: rgba(243, 186, 47, 0.3);
    }

    .card-help-title {
        color: #f3ba2f;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.13em;
        font-weight: 900;
    }

    .card-help-text,
    .card-help-calc {
        margin-top: 8px;
        color: rgba(255, 255, 255, 0.82);
        font-size: 14px;
        line-height: 1.45;
    }

    .card-help-calc strong {
        color: #f3ba2f;
        font-weight: 800;
    }

    .card-help-list {
        margin-top: 8px;
        color: rgba(255, 255, 255, 0.7);
        font-size: 13px;
        line-height: 1.45;
        padding-left: 18px;
        list-style: disc;
    }

    @media (max-width: 768px) {
        .card-help-trigger {
            width: 26px;
            height: 26px;
            font-size: 16px;
        }

        .card-help-popover {
            width: calc(100vw - 12px);
            max-width: none;
            border-radius: 16px;
            padding: 16px 18px;
        }

        .card-help-title {
            font-size: 14px;
            letter-spacing: 0.12em;
        }

        .card-help-text,
        .card-help-calc {
            font-size: 16px;
            line-height: 1.5;
        }

        .card-help-list {
            font-size: 15px;
            line-height: 1.5;
            padding-left: 20px;
        }
    }

    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #0b0e11; }
    ::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: #F3BA2F; }

    html, body {
        width: 100%;
        max-width: 100%;
        overflow-x: hidden;
    }
</style>
